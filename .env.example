# AIS-OS Environment Variables
# Copy to .env and fill in values. Never commit .env (gitignored).
#
# Audited against actual usage in tower/, dashboards/, scripts/, plus a live
# check on Cortex (docker inspect + docker-compose.yml) on 2026-07-05.
# `~/stack/docker-compose.yml` on Cortex (not in this repo) loads this whole
# file via a blanket `env_file: .env` — no per-var `environment:` mapping —
# so `stack-tower-1` and `stack-mcp-azure-devops-1` both see every var below
# whether they use it or not. AZURE_DEVOPS_PAT_B64 was removed 2026-07-05:
# it duplicated PERSONAL_ACCESS_TOKEN (same secret, confirmed via docker
# inspect), was never read directly by anything, and docker-compose.yml has
# no reference to it — consolidated to PERSONAL_ACCESS_TOKEN, the name the
# actual consumer (@azure-devops/mcp npm package) reads.

# ============================================================
# REQUIRED — core features break without these
# ============================================================

# --- Azure DevOps --- (tower/readers/ado_update.py, tower/interrupts/ado_push.py,
# scripts/devops_summary.py, dashboards/claudia/server.py)
# Org name from dev.azure.com/<org>
AZURE_DEVOPS_ORG=MAGIQSoftware
# ADO project name
AZURE_DEVOPS_PROJECT=Media
# Personal Access Token — Work Items (read/write) + Code (read) scopes
AZURE_DEVOPS_PAT=

# Same PAT, base64-encoded as "<anything>:<pat>" — required by the official
# @azure-devops/mcp npm package, which reads this exact var name (see
# GETTINGSTARTED.md in microsoft/azure-devops-mcp; also mcp/azure-devops/
# Dockerfile). Consumed on Cortex by the `mcp-azure-devops` container
# (stack-mcp-azure-devops-1, confirmed via docker inspect + docker-compose.yml
# 2026-07-05). On Windows/WSL with the literal-node-path form of .mcp.json
# (the one currently in use, not .mcp.json.example's dockerized form), this
# line is unused — safe to leave blank there, but keep it set on Cortex.
# Regenerate alongside AZURE_DEVOPS_PAT whenever it rotates — don't let the
# two drift.
# Generate: echo -n "chase:$AZURE_DEVOPS_PAT" | base64
PERSONAL_ACCESS_TOKEN=

# --- Anthropic --- (tower/standup.py hard-requires this — KeyError if unset;
# tower/interrupts/email.py for brief/email draft generation)
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Cloudflare API --- (api key required by traefik to resolve certificates)
CF_DNS_API_TOKEN=

# ============================================================
# CONDITIONAL — required for specific deployments/features, not local dev
# ============================================================

# GitHub — required in the Cortex container only. `gh` has no interactive
# login there and picks this up automatically (tower/readers/github.py PR
# queue reader). Not needed on Windows/WSL where `gh` is already logged in.
GH_TOKEN=ghp_...

# Control Tower access token — required once Tower is reachable beyond
# localhost (e.g. the Cortex deployment). Empty = open access (fine for
# local dev). (tower/config.py)
TOWER_TOKEN=

# Comma-separated CORS origins for Tower's /api. Required alongside
# TOWER_TOKEN for non-localhost deployments. (tower/server.py)
TOWER_ALLOWED_ORIGINS=http://localhost:8765,https://tower.ramonedevelopment.com

# Claudia bridge — Cortex only. Points at scripts/claudia-bridge/server.py,
# the host-side (non-Docker) HTTP wrapper Tower uses to reach the bare-metal
# `claudia` CLI — the only working path from inside Cortex's containerized
# Tower. (tower/server.py, tower/readers/claudia.py)
#
# WRINKLE: Windows/WSL and Cortex share this one .env file. Setting this
# breaks "Ask Claudia" on a Windows/WSL Tower instance (`host.docker.internal`
# doesn't resolve outside a container) while fixing it on Cortex — you can't
# have both from one shared value. Leave unset on Windows/WSL dev.
CLAUDIA_BRIDGE_URL=http://host.docker.internal:8901

# ============================================================
# OPTIONAL — sensible built-in defaults, override only if needed
# ============================================================

# Control Tower port. Default: 8765 (tower/config.py, tower/start.py)
TOWER_PORT=8765

# Hermes home directory. Default: ~/.hermes (dashboards/claudia/server.py)
HERMES=

# Hermes projects data dir. Default: /opt/data/.hermes/data/projects
# (scripts/auto-scaffold.ps1)
HERMES_DATA=

# Override repo root. Leave unset — scripts self-locate from their own file
# path. (tower/config.py, dashboards/claudia/server.py)
AIOS_ROOT=

# Notion — meeting notes/docs integration (references/notion-api.md).
# Not yet read by any script in this repo; set once that wiring lands.
NOTION_TOKEN=ntn_...


