# AIS-OS Environment Variables
# Copy to .env and fill in values. Never commit .env (gitignored).
#
# Internal repo paths self-locate — you do NOT need to set AIOS_ROOT after moving
# the folder. Only set the vars below that point OUTSIDE the repo or hold secrets.

# --- Paths (all optional — sensible defaults shown) ---
# AIOS_ROOT=            # Override repo root. Leave unset — scripts self-locate.
# HERMES=               # Hermes home dir. Default: ~/.hermes
# HERMES_DATA=          # Hermes projects data dir (inside container). Default: /opt/data/.hermes/data/projects
# TOWER_PORT=8765       # Control Tower port
# MCP_ADO_SERVER=       # Path to azure-devops MCP server entry (e.g. /path/to/azure-devops-mcp-server/build/index.js)

# --- Control Tower ---
# Access token for /api. Set to require Authorization: Bearer <token>. Empty = open (localhost dev).
# REQUIRED when Tower is reachable beyond localhost (e.g. the Cortex deployment).
TOWER_TOKEN=
# Comma-separated CORS origins. Default covers localhost dev only.
# Cortex deployment: http://localhost:8765,https://tower.ramonedevelopment.com
TOWER_ALLOWED_ORIGINS=

# --- GitHub (required in the Cortex container — `gh` has no interactive login there) ---
# Fine-grained PAT, read-only on repos/PRs is enough. `gh` picks this up automatically.
GH_TOKEN=

# --- Claudia bridge (Cortex only — leave unset on Windows dev) ---
# Points at scripts/claudia-bridge/server.py, a host-side (non-Docker) HTTP
# wrapper around the bare-metal `claudia` CLI. Unset = Tower falls back to
# `docker exec hermes ...` (Windows dev, Hermes-in-Docker).
CLAUDIA_BRIDGE_URL=http://host.docker.internal:8901

# --- Azure DevOps (required for interrupt/ADO push + dashboard DevOps cards) ---
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=
# Same PAT, base64-encoded as "<anything>:<pat>", required by the dockerized
# azure-devops-mcp server (Claude Code + Claudia). Regenerate this alongside
# AZURE_DEVOPS_PAT whenever it rotates — don't let the two drift.
# Generate: echo -n "chase:$AZURE_DEVOPS_PAT" | base64
AZURE_DEVOPS_PAT_B64=

# --- Notion (optional — meeting notes / docs, once wired) ---
NOTION_TOKEN=

# --- Anthropic (required for email/brief draft generation) ---
ANTHROPIC_API_KEY=
