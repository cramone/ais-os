# AIS-OS Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Paths (optional — defaults to Chase's machine paths)
# AIOS_ROOT=C:\Users\chase\OneDrive\Magiq\AIS-OS
# HERMES=C:\Users\chase\.hermes
# TOWER_PORT=8765

# Azure DevOps (required for interrupt ADO push)
ADO_ORG=
ADO_PROJECT=
ADO_PAT=

# Anthropic (required for email draft generation)
ANTHROPIC_API_KEY=
