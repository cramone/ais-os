# AIS-OS Environment Variables
# Copy to .env and fill in values. Never commit .env (gitignored).
#
# Internal repo paths self-locate — you do NOT need to set AIOS_ROOT after moving
# the folder. Only set the vars below that point OUTSIDE the repo or hold secrets.

# --- Paths (all optional — sensible defaults shown) ---
# AIOS_ROOT=            # Override repo root. Leave unset — scripts self-locate.
# HERMES=               # Hermes home dir. Default: ~/.hermes
# HERMES_DATA=          # Hermes projects data dir (inside container). Default: /opt/data/.hermes/data/projects
# TOWER_PORT=8765       # Control Tower port
# MCP_ADO_SERVER=       # Path to azure-devops MCP server entry (e.g. /path/to/azure-devops-mcp-server/build/index.js)

# --- Control Tower ---
# Access token for /api. Set to require Authorization: Bearer <token>. Empty = open (localhost dev).
TOWER_TOKEN=

# --- Azure DevOps (required for interrupt/ADO push + dashboard DevOps cards) ---
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=

# --- Notion (optional — meeting notes / docs, once wired) ---
NOTION_TOKEN=

# --- Anthropic (required for email/brief draft generation) ---
ANTHROPIC_API_KEY=
