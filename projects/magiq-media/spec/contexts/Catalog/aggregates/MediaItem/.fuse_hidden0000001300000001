## Write Model Service Interfaces

```csharp
/// <summary>
/// Write-side query service for MediaProfile data needed by MediaItem command handlers.
/// Used to validate asset roles and resolve published media-profile snapshots.
/// </summary>
interface IMediaProfileQueryService {
    /// <summary>
    /// Returns the published media-profile with CompiledTemplate, AssetDefinitions, RecordTypeRefs,
    /// and Capabilities. Returns null if not found or not Published.
    /// Used by CreateMediaItem, AssignAssetToRole, and Publish.
    /// </summary>
    Task<PublishedProfileReadModel?> GetPublishedAsync(TenantId tenantId, MediaProfileId profileId, CancellationToken ct = default);
}

/// <summary>
/// Write-side media-folder query service. Derives CollectionId from a FolderId — callers never
/// supply CollectionId directly. Also enforces title uniqueness within a media-folder scope.
/// </summary>
interface IFolderQueryService {
    /// <summary>
    /// Returns the active media-folder's CollectionId, or null if not found or archived.
    /// Used by CreateMediaItem, AssignMediaItemToFolder, and MoveMediaItem.
    /// </summary>
    Task<CollectionId?> GetActiveCollectionIdAsync(TenantId tenantId, FolderId folderId, CancellationToken ct = default);

    /// <summary>
    /// Returns true if the given name is already in use within the media-folder's scope.
    /// Used by UpdateMediaItemTitle to enforce uniqueness within the assigned media-folder.
    /// </summary>
    Task<bool> NameExistsInScopeAsync(TenantId tenantId, FolderId parentFolderId, string name, CancellationToken ct = default);
}

/// <summary>
/// Write-side asset query service for validating asset state during assignment and review submission.
/// </summary>
interface IAssetQueryService {
    /// <summary>Returns a single asset reference, or null if not found.</summary>
    Task<MediaItemAssetReference?> GetAsync(TenantId tenantId, AssetId assetId, CancellationToken ct = default);

    /// <summary>Batch-fetches asset references for all given AssetIds.</summary>
    Task<IReadOnlyList<MediaItemAssetReference>> GetManyAsync(TenantId tenantId, IReadOnlyList<AssetId> assetIds, CancellationToken ct = default);
}

/// <summary>Supporting record returned by IMediaProfileQueryService.GetPublishedAsync.</summary>
sealed record PublishedProfileReadModel(
    MediaProfileId MediaProfileId,
    int Version,
    CompiledMetadataTemplate CompiledTemplate,
    IReadOnlyList<RecordTypeVersion> RecordTypeRefs,
    IReadOnlyList<AssetDefinition> AssetDefinitions,
    CapabilitySet Capabilities
);

/// <summary>
/// Supporting record returned by IAssetQueryService.
/// Storage fields (FileName, SourceStorageKey, Renditions) are populated from the
/// AssetStateReference projection — captured at upload and processing time.
/// These fields may be null for assets that have not yet completed processing.
/// </summary>
sealed record MediaItemAssetReference(
    AssetId AssetId,
    AssetStatus Status,
    MediaContentType ContentType,
    string? FileName,
    string? SourceStorageKey,
    IReadOnlyList<AssetRenditionReference> Renditions);

sealed record AssetRenditionReference(string RenditionType, string StorageKey, string ContentType);
```

