### Step 4 — Create `IMagiqJwtTokenFactory`
**File:** `src/MagiqAuth.Services/Authentication/IMagiqJwtTokenFactory.cs` *(new)*

```csharp
using MagiqAuth.Core.Domain.Users;
using MagiqAuth.Web.Api.v1.Models.Security;

namespace MagiqAuth.Services.Authentication;

public interface IMagiqJwtTokenFactory
{
    /// <summary>User-only token — no tenant/customer context (all-tenants login).</summary>
    JwtToken BuildUserToken(User user);

    /// <summary>Customer-scoped token — includes LoginID and CustomerName.</summary>
    JwtToken BuildCustomerToken(User user, string customerName, string loginId);
}
```

---

### Step 5 — Create `MagiqJwtTokenFactory`
**File:** `src/MagiqAuth.Services/Authentication/MagiqJwtTokenFactory.cs` *(new)*

```csharp
using MagiqAuth.Core.Configuration;
using MagiqAuth.Core.Domain.Users;
using MagiqAuth.Core.Security;
using MagiqAuth.Web.Api.v1.Models.Security;

namespace MagiqAuth.Services.Authentication;

public class MagiqJwtTokenFactory : IMagiqJwtTokenFactory
{
    private readonly MagiqConfig _config;

    public MagiqJwtTokenFactory(MagiqConfig config)
    {
        _config = config;
    }

    public JwtToken BuildUserToken(User user)
    {
        var claims = MagiqClaimsFactory.BuildUserClaims(
            user.FirstName, user.LastName, user.UserGuid.ToString());

        return BuildToken(user.Email, claims);
    }

    public JwtToken BuildCustomerToken(User user, string customerName, string loginId)
    {
        var claims = MagiqClaimsFactory.BuildCustomerClaims(
            user.FirstName, user.LastName, user.UserGuid.ToString(), loginId, customerName);

        return BuildToken(user.Email, claims);
    }

    private JwtToken BuildToken(string subject, IEnumerable<Claim> claims)
    {
        var issuerAudience = "https://" + _config.Site.Domain;
        var builder = new JwtTokenBuilder()
            .AddSecurityKey(_config.Security.SecurityKey)
            .AddSubject(subject)
            .AddIssuer(issuerAudience)
            .AddAudience(issuerAudience)
            .AddExpiry(10);

        foreach (var claim in claims)
            builder.AddClaim(claim.Type, claim.Value);

        return builder.Build();
    }
}
```

---

### Step 6 — Register factory in DI
**File:** `src/MagiqAuth.Web.Framework/Infrastructure/Extensions/ServiceCollectionExtensions.cs`

```csharp
services.AddScoped<IMagiqJwtTokenFactory, MagiqJwtTokenFactory>();
```

---

### Step 7 — Refactor `JwtAuthV1Controller`
**File:** `src/MagiqAuth.Web/Api/v1/Controllers/JwtAuthV1Controller.cs`

- Inject `IMagiqJwtTokenFactory _tokenFactory`
- `LoginCustomerInternal`: replace `new JwtTokenBuilder()...Build()` with `_tokenFactory.BuildCustomerToken(user, userCustomer.Customer.Name, userCustomer.LoginId)`
- `LoginCustomersInternal`: replace with `_tokenFactory.BuildUserToken(user)` (all-tenants path — no single customer in scope)

---

### Step 8 — Refactor `JwtAuthV2Controller`
**File:** `src/MagiqAuth.Web/Api/v1/Controllers/JwtAuthV2Controller.cs`

- Inject `IMagiqJwtTokenFactory _tokenFactory`
- `Login` (no-customer path): replace with `_tokenFactory.BuildUserToken(user)`
- `LoginCustomerInternal`: replace with `_tokenFactory.BuildCustomerToken(user, userCustomer.Customer.Name, userCustomer.LoginId)`
- `LoginCustomersInternal`: replace with `_tokenFactory.BuildUserToken(user)`
- `Verify` (post-2FA): replace with `_tokenFactory.BuildCustomerToken(user, customer.Name, loginId)` — **fixes missing claims and wrong issuer**

