### Update `MagiqClientStore` — Handle `ApiClient` lookup

**File: `src/MagiqAuth.Services/Authentication/MagiqClientStore.cs`**

Add `IApiClientService` dependency and extend `FindClientByIdAsync`:

```csharp
public MagiqClientStore(
    ICustomerService customerService,
    IApplicationService applicationService,
    IApiClientService apiClientService,        // NEW
    ILogger logger,
    IHttpContextAccessor httpContextAccessor,
    MagiqConfig magiqConfig)
{
    _customerService = customerService;
    _applicationService = applicationService;
    _apiClientService = apiClientService;      // NEW
    _logger = logger;
    _httpContextAccessor = httpContextAccessor;
    _magiqConfig = magiqConfig;
}
```

In `FindClientByIdAsync`, add the `ApiClient` lookup **before** the existing `AppRegistration` check:

```csharp
public async Task<Client> FindClientByIdAsync(string clientId)
{
    if (string.IsNullOrEmpty(clientId) || !Guid.TryParse(clientId, out var clientGuid))
        return null;

    try
    {
        // 1. Machine client (client credentials) — check first, no tenant context needed from request
        var apiClient = _apiClientService.GetApiClientByGuid(clientGuid);
        if (apiClient is not null)
            return CreateClientForApiClient(apiClient);

        // 2. Customer OIDC client (existing behaviour)
        var customer = await _customerService.GetCustomerByGuidAsync(clientGuid);
        if (customer is not null)
            return CreateClientForCustomer(customer);

        // 3. AppRegistration OIDC client (existing behaviour)
        var appRegistration = _applicationService.GetApplicationByGuid(clientGuid);
        if (appRegistration is null)
            return null;

        if (!TryGetTenantNameOrIdFromRequest(_httpContextAccessor.HttpContext?.Request, out var tenantNameOrId))
            return CreateClientForAppRegistration(appRegistration);

        customer = Guid.TryParse(tenantNameOrId, out var tenantId)
            ? await _customerService.GetCustomerByGuidAsync(tenantId)
            : await _customerService.GetCustomerByNameAsync(tenantNameOrId);

        return customer is not null
            ? CreateClientForApplicationWithTenantContext(appRegistration, customer)
            : CreateClientForAppRegistration(appRegistration);
    }
    catch (Exception ex)
    {
        _logger.Error(ex.Message, ex);
        return null;
    }
}

private Client CreateClientForApiClient(ApiClient apiClient)
{
    var scopes = apiClient.AllowedScopes
        .SplitCommaSemicolonSeparated()
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .ToList();

    return new Client
    {
        ClientId = apiClient.ClientGuid.ToString(),
        ClientName = apiClient.Name,
        AllowedGrantTypes = GrantTypes.ClientCredentials,
        AccessTokenType = AccessTokenType.Jwt,
        ClientSecrets = GetSecrets(apiClient.ClientSecretHash),
        AllowedScopes = scopes,
        AccessTokenLifetime = apiClient.AccessTokenLifetimeSeconds,
        IncludeJwtId = true,
        RequireClientSecret = true,
        // TenantId baked into token — hard-locked to the customer set at creation
        Claims = new[]
        {
            new ClientClaim(MagiqClaimsFactory.TenantId, apiClient.CustomerGuid.ToString())
        },
        AlwaysSendClientClaims = true
    };
}
```

> No redirect URIs, no offline access, no PKCE — machine clients don't need any of that.  
> `CustomerGuid` is never overridable at token-request time — it is baked in via `Client.Claims`.

### Management API: `ApiClientsController`

**File: `src/MagiqAuth.Api/Controllers/ApiClientsController.cs`**

```
[Route("auth/v2/api-clients")]
```

| Method | Route | Description |
|--------|-------|-------------|
| GET | `/` | List all (non-deleted) API clients |
| GET | `/{id:int}` | Get by internal ID |
| GET | `/{clientGuid:guid}` | Get by client GUID |
| GET | `/by-customer/{customerGuid:guid}` | List all clients for a tenant |
| POST | `/` | Create new API client → returns `{ clientId, clientSecret }` once |
| PUT | `/` | Update name/description/scopes/lifetime/isActive |
| POST | `/{clientGuid}/secret` | Rotate secret → returns new `{ clientId, clientSecret }` once |
| DELETE | `/{clientGuid}` | Soft-delete (sets `IsDeleted = true`) |

**Secret helper (shared by create and rotate):**

```csharp
private static string GenerateSecret()
{
    var bytes = new byte[32];
    RandomNumberGenerator.Fill(bytes);
    return Convert.ToHexString(bytes).ToLowerInvariant(); // 64 hex chars, 256-bit entropy
}
```

**Create endpoint behaviour:**

```csharp
[HttpPost]
public IActionResult CreateApiClient(CreateApiClientModel model)
{
    var customer = _customerService.GetCustomerByGuid(model.CustomerGuid);
    if (customer is null) return BadRequest("Customer not found.");

    var rawSecret = GenerateSecret();
    var client = new ApiClient
    {
        ClientGuid = Guid.NewGuid(),
        Name = model.Name,
        Description = model.Description,
        ClientSecretHash = rawSecret.Sha256(),
        AllowedScopes = model.AllowedScopes ?? "magiq-api",
        AccessTokenLifetimeSeconds = model.AccessTokenLifetimeSeconds > 0
            ? model.AccessTokenLifetimeSeconds
            : 3600,
        IsActive = true,
        IsDeleted = false,
        CustomerId = customer.Id,
        CustomerGuid = customer.CustomerGuid,
        CreatedOnUtc = DateTime.UtcNow,
        UpdatedOnUtc = DateTime.UtcNow
    };

    _apiClientService.InsertApiClient(client);
    _activityLogService.InsertActivityLog("ApiClient.Created",
        $"API client '{client.Name}' ({client.ClientGuid}) created for customer {customer.Name}");

    // Raw secret returned ONCE — not stored, cannot be retrieved again
    return Ok(new
    {
        clientId = client.ClientGuid,
        clientSecret = rawSecret,
        message = "Store this secret securely. It will not be shown again."
    });
}
```

**Secret rotation endpoint:**

```csharp
[HttpPost("{clientGuid:guid}/secret")]
public IActionResult RotateSecret(Guid clientGuid)
{
    var client = _apiClientService.GetApiClientByGuid(clientGuid);
    if (client is null) return NotFound();

    var rawSecret = GenerateSecret();
    client.ClientSecretHash = rawSecret.Sha256();
    client.UpdatedOnUtc = DateTime.UtcNow;
    _apiClientService.UpdateApiClient(client);
    _activityLogService.InsertActivityLog("ApiClient.SecretRotated",
        $"Secret rotated for API client '{client.Name}' ({client.ClientGuid})");

    return Ok(new
    {
        clientId = client.ClientGuid,
        clientSecret = rawSecret,
        message = "Store this secret securely. It will not be shown again."
    });
}
```

**Delete endpoint:**

```csharp
[HttpDelete("{clientGuid:guid}")]
public IActionResult DeleteApiClient(Guid clientGuid)
{
    var client = _apiClientService.GetApiClientByGuid(clientGuid);
    if (client is null) return NotFound();

    client.IsDeleted = true;
    client.UpdatedOnUtc = DateTime.UtcNow;
    _apiClientService.UpdateApiClient(client);
    _activityLogService.InsertActivityLog("ApiClient.Deleted",
        $"API client '{client.Name}' ({client.ClientGuid}) soft-deleted");

    return Ok();
}
```

