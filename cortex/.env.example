# cortex-local secrets — docker-compose.yml variable substitution
#
# COPY THIS FILE TO: ~/stack/.env on cortex ITSELF. Nowhere else.
#
# This is NOT the same file as this repo's own .env.example (which documents
# /mnt/shared/claudia/magiq/.env, loaded via `env_file:` into the tower and
# mcp-azure-devops containers). That file lives on the NAS share and is
# readable by anything with access to this repo, including AI sessions
# editing docker-compose.yml. This one is different on purpose:
#
#   - Fill in real values, then `cp` this to ~/stack/.env on cortex directly
#     (e.g. via SSH/nano), never through the /mnt/shared/claudia/magiq share.
#   - `~/stack/.env` must never be copied back onto the NAS share, never
#     committed to git, never pasted into a chat session.
#   - `chmod 600 ~/stack/.env` after creating it.
#   - Docker Compose auto-substitutes ${VAR} in docker-compose.yml from a
#     .env file in the same directory — this is why it must sit next to
#     docker-compose.yml in ~/stack, not anywhere else.
#
# Decided 2026-07-05 — see decisions/log.md ("Secrets extracted from
# docker-compose.yml to local-only .env") and setup guide Stage 22.
# Relocated into cortex/ alongside docker-compose.yml on 2026-07-05 — this
# subfolder holds everything specific to the cortex box's docker-compose
# stack, symlinked into ~/stack there (Stage 22.4).

# ============================================================
# REQUIRED — the mysql, sqlserver, and seq containers won't start without these
# ============================================================

# Root password for the `mysql` service (mysql:8.4). Read by docker-compose.yml's
# `environment: MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}`. Also whatever
# CloudBeaver's MySQL connection (Stage 19.4) should authenticate with as `root`.
MYSQL_ROOT_PASSWORD=

# `sa` account password for the `sqlserver` service (mssql/server:2022-latest,
# Developer edition). Read by docker-compose.yml's
# `environment: SA_PASSWORD: "${MSSQL_SA_PASSWORD}"`. Also whatever CloudBeaver's
# SQL Server connection (Stage 19.4) should authenticate with as `sa`.
#
# Note: this is a DIFFERENT variable name from the container's own internal
# SA_PASSWORD env var the healthcheck reads via `$$SA_PASSWORD` — Compose
# substitutes this value INTO that container env var at creation time, so
# there's no naming collision, just don't confuse the two when debugging.
MSSQL_SA_PASSWORD=

# SMB password for the `svc-shared` service account on the DS923 NAS
# (ramonenas.tail926842.ts.net). Read by the top-level `shared_data` volume's
# `driver_opts.o` CIFS mount string. Same account/password Stage 14.1 set up
# on the DS923 itself — this must match what's configured there, not a value
# you invent independently.
CIFS_SHARED_PASSWORD=

# First-run admin password for the `seq` service (datalust/seq:latest). Read by
# docker-compose.yml's `environment: SEQ_FIRSTRUN_ADMINPASSWORD: ${SEQ_FIRSTRUN_ADMINPASSWORD}`.
# Required as of Seq 2025.2.x — without it the container crash-loops on boot with
# "No default admin password was supplied" (confirmed 2026-07-05). Log in to
# logs.ramonedevelopment.com as user `admin` with this password on first load.
SEQ_FIRSTRUN_ADMINPASSWORD=
